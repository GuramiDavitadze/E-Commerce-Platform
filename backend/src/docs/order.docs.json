{
    "/api/orders/my-orders": {
        "post": {
            "summary": "Make New Order",
            "tags": [
                "Orders"
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "products"
                            ],
                            "properties": {
                                "products": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "required": [
                                            "product_id",
                                            "price"
                                        ],
                                        "properties": {
                                            "product_id": {
                                                "type": "string",
                                                "example": "16934584-990d-459b-bf95-0ec233cf3eab"
                                            },
                                            "price": {
                                                "type": "number",
                                                "example": 99.99
                                            },
                                            "quantity": {
                                                "type": "number",
                                                "example": 1
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Order Created Successfully"
                },
                "400": {
                    "description": "Validation Error"
                },
                "404": {
                    "description": "Product Not Found"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        },
        "get": {
            "summary": "Get All Orders",
            "tags": [
                "Orders"
            ],
            "responses": {
                "200": {
                    "description": "Get All Orders"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    },
    "/api/orders/admin": {
        "get": {
            "summary": "All Orders of all users",
            "tags": [
                "Orders"
            ],
            "responses": {
                "200": {
                    "description": "Get All Orders"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "403": {
                    "description": "Access Denided"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    },
    "/api/orders/{id}/status": {
        "parameters": [
            {
                "name": "id",
                "in": "path",
                "required": true,
                "schema": {
                    "type": "string"
                },
                "example": "16934584-990d-459b-bf95-0ec233cf3eab"
            }
        ],
        "patch": {
            "summary": "Update Order Status",
            "tags": [
                "Orders"
            ],
            "responses": {
                "200": {
                    "description": "Updated order status"
                },
                "400": {
                    "description": "Already Delivered"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "403": {
                    "description": "Access Denided"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    },
    "/api/orders/{id}": {
        "parameters": [
            {
                "name": "id",
                "in": "path",
                "required": true,
                "schema": {
                    "type": "string"
                },
                "example": "16934584-990d-459b-bf95-0ec233cf3eab"
            }
        ],
        "patch": {
            "summary": "Cancell Order",
            "tags": [
                "Orders"
            ],
            "responses": {
                "200": {
                    "description": "Order Cancelled successfully"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "403": {
                    "description": "Don't have permission to Cancell"
                },
                "404": {
                    "description": "Order Not Found"
                },
                "409": {
                    "description": "Order Cannot be Cancelled"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    }
}