{
    "/api/comments/product/{product_id}": {
        "post": {
            "summary": "Create New Comment by product id",
            "tags": [
                "Comments"
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "text"
                            ],
                            "properties": {
                                "text": {
                                    "type": "string",
                                    "example": "This is very good product"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Comment created successfully"
                },
                "400": {
                    "description": "Validation Error"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        },
        "get": {
            "summary": "Get All comments by product by product id",
            "tags": [
                "Comments"
            ],
            "responses": {
                "200": {
                    "description": "Get All Products"
                },
                "400": {
                    "description": "Validation Error"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    },
    "/api/comments/{id}": {
        "patch": {
            "summary": "Update comment by comment id",
            "tags": [
                "Comments"
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "text"
                            ],
                            "properties": {
                                "text": {
                                    "type": "string",
                                    "example": "This is very good product"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Comment Updated Successfully"
                },
                "400": {
                    "description": "Validation Error"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "404": {
                    "description": "Comment Does not exist"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        },
        "delete": {
            "summary": "Delete Comment By Comment Id",
            "tags": [
                "Comments"
            ],
            "responses": {
                "200": {
                    "description": "Comment Deleted Successfully"
                },
                "401": {
                    "description": "Unauthorized"
                },
                "404": {
                    "description": "Comment Not Found"
                },
                "500": {
                    "description": "Internal Server Error"
                }
            }
        }
    }
}